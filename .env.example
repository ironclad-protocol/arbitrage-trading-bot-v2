PRIVATE_KEY=your_base58_private_key_here

RPC_MAINNET_URL=https://mainnet.helius-rpc.com/?api-key=

HELIUS_GEYSER_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=

# Set to true or 1 to only simulate transactions (no on-chain send/confirm)
# SIMULATION_MODE=true

# --- Transaction landing (see utils/tx-submitters/) ---
# TX_SUBMITTER=nextblock | helius-sender | astralane | zeroslot | jito
# TX_SUBMITTER=jito

# Helius Sender (tip min ~0.0002 SOL; also set compute unit price on tx)
# HELIUS_SENDER_URL=https://sender.helius-rpc.com/fast
# HELIUS_SENDER_TIP_SOL=0.0002

# Astralane Iris (portal.astralane.io)
# ASTRALANE_API_KEY=
# ASTRALANE_IRIS_BASE=https://fr.gateway.astralane.io/iris
# ASTRALANE_TIP_SOL=0.00002

# Zeroslot (0slot.trade)
# ZEROSLOT_API_KEY=
# ZEROSLOT_URL=https://de.0slot.trade
# ZEROSLOT_TIP_SOL=0.001